---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Ray — Dashboard PC">
  <div class="min-h-screen flex flex-col items-center justify-center p-6">

    <!-- Header -->
    <header class="w-full max-w-[480px] flex items-center justify-between mb-8">
      <div class="text-xl font-semibold tracking-tight">
        Ray<span class="text-violet-500">·</span>
      </div>
      <div class="flex items-center gap-2 text-sm text-zinc-500">
        <div id="conn-dot" class="w-2 h-2 rounded-full bg-zinc-600"></div>
        <span id="conn-text">Sin conexión</span>
      </div>
    </header>

    <!-- Main Card -->
    <main class="w-full max-w-[480px]">
      <div class="bg-zinc-900 border border-zinc-800 rounded-2xl p-8">

        <p class="text-[11px] font-medium tracking-[0.2em] text-zinc-500 uppercase mb-3">
          Código de sala
        </p>

        <!-- Room code -->
        <div id="room-code"
          class="font-mono font-bold text-5xl text-violet-400 tracking-widest mb-8 select-all cursor-pointer"
          title="Clic para copiar">
          ——————
        </div>

        <!-- Divider -->
        <div class="border-t border-zinc-800 mb-6"></div>

        <!-- Buttons -->
        <div class="flex gap-3">
          <button id="btn-copy"
            class="flex-1 h-10 border border-zinc-700 text-zinc-300 rounded-xl text-sm font-medium hover:bg-zinc-800 transition-colors">
            Copiar código
          </button>
          <button id="btn-new"
            class="flex-1 h-10 border border-zinc-700 text-zinc-300 rounded-xl text-sm font-medium hover:bg-zinc-800 transition-colors">
            Nuevo código
          </button>
        </div>

        <!-- Footer status -->
        <div class="mt-6 flex items-center gap-2 text-sm text-zinc-500">
          <div id="footer-dot" class="w-1.5 h-1.5 rounded-full bg-zinc-600"></div>
          <span id="footer-text">Abre Ray App en tu celular e ingresa el código</span>
        </div>

      </div>

      <!-- Instructions -->
      <ol class="mt-6 text-sm text-zinc-500 space-y-2 list-none">
        <li class="flex gap-3">
          <span class="text-zinc-700 font-mono">1.</span>
          Abre Ray App en tu celular
        </li>
        <li class="flex gap-3">
          <span class="text-zinc-700 font-mono">2.</span>
          Ingresa el código que ves arriba
        </li>
        <li class="flex gap-3">
          <span class="text-zinc-700 font-mono">3.</span>
          El agente Python debe estar corriendo en este PC
        </li>
      </ol>
    </main>

  </div>
</Layout>

<script is:inline>
  // 1. Mostrar código visualmente INMEDIATO antes que nada
  function genCode() {
    const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
    return 'RAY-' + Array.from({length: 4}, () => chars[Math.floor(Math.random() * chars.length)]).join('');
  }

  let roomCode = localStorage.getItem('ray_room_code') || genCode();
  localStorage.setItem('ray_room_code', roomCode);
  
  const rcEl = document.getElementById('room-code');
  if (rcEl) {
    rcEl.textContent = roomCode;
  }

  // UI helpers
  function setStatus(online) {
    const connDot  = document.getElementById('conn-dot');
    const connText = document.getElementById('conn-text');
    const fDot     = document.getElementById('footer-dot');
    const fText    = document.getElementById('footer-text');
    if (!connDot) return;

    if (online) {
      connDot.className  = 'w-2 h-2 rounded-full bg-green-500 shadow-[0_0_6px_rgba(34,197,94,0.6)]';
      connText.textContent = 'Conectado';
      connText.className = 'text-sm text-green-400';
      fDot.className     = 'w-1.5 h-1.5 rounded-full bg-green-500';
      fText.textContent  = 'Celular conectado — puedes enviar comandos desde Ray App';
      fText.className    = 'text-sm text-green-400';
    } else {
      connDot.className  = 'w-2 h-2 rounded-full bg-zinc-600';
      connText.textContent = 'Sin conexión';
      connText.className = 'text-sm text-zinc-500';
      fDot.className     = 'w-1.5 h-1.5 rounded-full bg-zinc-600';
      fText.textContent  = 'Abre Ray App en tu celular e ingresa el código';
      fText.className    = 'text-sm text-zinc-500';
    }
  }

  // 2. Inicializar Supabase sólo cuando esté disponible
  const SUPABASE_URL = 'https://wnxuozsztttajoamhmmd.supabase.co';
  const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6IndueHVvenN6dHR0YWpvYW1obW1kIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ0MDM1MzgsImV4cCI6MjA4OTk3OTUzOH0.cRIDgZfnjrVuDprxubj_PDYvlN8j62Oyvhn8KhJh4oM';

  function initConn() {
    if (typeof supabase === 'undefined') {
      setTimeout(initConn, 200);
      return;
    }

    try {
      const sb = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

      sb.from('rooms').select('*').eq('room_code', roomCode).single()
      .then(({data}) => {
        if (!data) {
           sb.from('rooms').insert({
             room_code: roomCode,
             pc_name: navigator.platform || 'PC',
             is_online: false,
             last_seen: new Date().toISOString()
           }).then();
        } else {
           setStatus(data.is_online === true || data.is_online === 'true');
        }
      });

      sb.channel('room-pc').on('postgres_changes', {
        event: 'UPDATE', schema: 'public', table: 'rooms'
      }, function(p) {
        const r = p.new;
        if (r.room_code === roomCode) {
          setStatus(r.is_online === true || r.is_online === 'true');
        }
      }).subscribe();
    } catch (err) {
      console.error("Error setting up Supabase:", err);
    }
  }
  initConn();

  // Buttons
  document.getElementById('btn-copy').addEventListener('click', function() {
    navigator.clipboard.writeText(roomCode);
    this.textContent = '¡Copiado!';
    setTimeout(() => this.textContent = 'Copiar código', 2000);
  });
  document.getElementById('room-code').addEventListener('click', function() {
    navigator.clipboard.writeText(roomCode);
  });
  document.getElementById('btn-new').addEventListener('click', function() {
    if (!confirm('¿Generar un nuevo código de sala?')) return;
    localStorage.removeItem('ray_room_code');
    location.reload();
  });
</script>
