---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Chat">
  <div class="chat-screen">
    <header class="chat-header">
      <button id="btn-back" class="btn-back">←</button>
      <div class="chat-info">
        <h2 id="chat-pc-name">PC</h2>
        <div class="chat-status">
          <div id="chat-dot" class="status-dot"></div>
          <span id="chat-status-text">Conectando...</span>
        </div>
      </div>
    </header>

    <div id="offline-banner" class="offline-banner hidden">
      ⚠ PC desconectado · Se reconectará al encender
    </div>

    <div id="chat-messages" class="chat-area"></div>

    <div class="chips">
      <button class="chip" data-cmd="abre YouTube">▶ YouTube</button>
      <button class="chip" data-cmd="busca algo en Google">🔍 Google</button>
      <button class="chip" data-cmd="abre Spotify">🎵 Spotify</button>
      <button class="chip" data-cmd="captura de pantalla">📸 Screenshot</button>
      <button class="chip" data-cmd="sube el volumen">🔊 Volumen</button>
    </div>

    <footer class="chat-footer">
      <button id="btn-mic" class="round-btn">🎙️</button>
      <input type="text" id="chat-input" class="chat-input" placeholder="Envía un comando...">
      <button id="btn-send" class="round-btn btn-send" disabled>➤</button>
    </footer>
  </div>
</Layout>

<style>
  .chat-screen { height: 100vh; display: flex; flex-direction: column; max-width: 500px; margin: 0 auto; }
  .chat-header {
    padding: 16px 20px; display: flex; align-items: center; gap: 14px;
    border-bottom: 1px solid var(--border); background: var(--card);
  }
  .btn-back { background: none; border: none; color: #fff; font-size: 22px; cursor: pointer; }
  .chat-info h2 { font-size: 1rem; margin: 0; }
  .chat-status { display: flex; align-items: center; gap: 6px; font-size: 0.75rem; color: var(--text-muted); }

  .offline-banner {
    background: rgba(255,152,0,0.1); color: var(--warning);
    font-size: 0.8rem; padding: 10px; text-align: center;
    border-bottom: 1px solid rgba(255,152,0,0.2);
  }

  .chat-area { flex: 1; overflow-y: auto; padding: 24px 20px; display: flex; flex-direction: column; gap: 16px; background: #0a0a0f; }

  .bubble {
    max-width: 85%; padding: 14px 18px; border-radius: 20px;
    font-size: 0.95rem; line-height: 1.5; word-break: break-word; font-family: 'Space Grotesk', sans-serif;
  }
  .user-msg {
    align-self: flex-end; background: #6c63ff; color: #fff;
    border-bottom-right-radius: 4px; box-shadow: 0 4px 15px rgba(108,99,255,0.25);
  }
  .ray-msg {
    align-self: flex-start; background: #1e1e2f; color: #f0f0f0;
    border-bottom-left-radius: 4px; border: 1px solid rgba(255,255,255,0.05);
  }
  .ray-avatar {
    display: inline-flex; width: 24px; height: 24px; background: var(--accent);
    border-radius: 50%; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 700; margin-right: 8px; vertical-align: middle;
  }

  .chips {
    padding: 10px 20px; display: flex; gap: 8px; overflow-x: auto; white-space: nowrap;
  }
  .chips::-webkit-scrollbar { display: none; }
  .chip {
    background: var(--surface); border: 1px solid var(--border); color: var(--text-muted);
    padding: 8px 14px; border-radius: 20px; font-size: 0.8rem; cursor: pointer; flex-shrink: 0;
  }
  .chip:hover { border-color: var(--accent); color: var(--accent); }

  .chat-footer {
    padding: 14px 20px; display: flex; align-items: center; gap: 10px; background: var(--card);
  }
  .chat-input { flex: 1; background: var(--bg); border-radius: 20px; padding: 12px 16px; }
  .round-btn {
    width: 44px; height: 44px; border-radius: 22px; border: none;
    background: var(--surface); color: #fff; display: flex;
    align-items: center; justify-content: center; cursor: pointer; font-size: 18px;
  }
  .btn-send:not(:disabled) { background: var(--accent); box-shadow: 0 0 10px var(--accent-glow); }
  .btn-mic.recording { background: var(--error); animation: pulse 1s infinite; }
</style>

<script>
  import { supabase } from '../../components/supabase.js';

  // ── Auth ──
  const { data: { session } } = await supabase.auth.getSession();
  if (!session) { window.location.href = '/app'; }

  // ── Room ──
  const params = new URLSearchParams(window.location.search);
  const roomCode = params.get('room');
  if (!roomCode) { window.location.href = '/app/dashboard'; }

  let roomId = '';
  let isOnline = false;

  async function loadRoom() {
    const { data } = await supabase.from('rooms').select('*').eq('room_code', roomCode).single();
    if (data) {
      roomId = data.id;
      document.getElementById('chat-pc-name')!.textContent = data.pc_name || roomCode;
      const lastSeen = new Date(data.last_seen).getTime();
      isOnline = data.is_online && (Date.now() - lastSeen < 65000);
      document.getElementById('chat-dot')!.className = `status-dot ${isOnline ? 'online' : ''}`;
      document.getElementById('chat-status-text')!.textContent = isOnline ? 'En línea' : 'Desconectado';
      document.getElementById('offline-banner')!.classList.toggle('hidden', isOnline);
    }
  }

  await loadRoom();
  setInterval(loadRoom, 10000);

  // ── Messages ──
  const chatArea = document.getElementById('chat-messages')!;
  const input = document.getElementById('chat-input') as HTMLInputElement;
  const btnSend = document.getElementById('btn-send') as HTMLButtonElement;

  input.addEventListener('input', () => { btnSend.disabled = !input.value.trim(); });
  input.addEventListener('keydown', (e) => { if (e.key === 'Enter' && input.value.trim()) sendMessage(); });
  btnSend.addEventListener('click', sendMessage);

  function addBubble(text: string, type: 'user' | 'ray') {
    const div = document.createElement('div');
    div.className = `bubble ${type === 'user' ? 'user-msg' : 'ray-msg'}`;
    if (type === 'ray') {
      div.innerHTML = `<span class="ray-avatar">R</span>${text}`;
    } else {
      div.textContent = text;
    }
    chatArea.appendChild(div);
    chatArea.scrollTop = chatArea.scrollHeight;
  }

  async function sendMessage() {
    const text = input.value.trim();
    if (!text || !roomId) return;
    input.value = '';
    btnSend.disabled = true;

    addBubble(text, 'user');

    // Add typing indicator
    const typing = document.createElement('div');
    typing.className = 'bubble ray-msg';
    typing.id = 'typing';
    typing.innerHTML = '<span class="ray-avatar">R</span><div class="typing-dots"><div></div><div></div><div></div></div>';
    chatArea.appendChild(typing);
    chatArea.scrollTop = chatArea.scrollHeight;

    // Insert command
    await supabase.from('commands').insert({
      room_id: roomId,
      input: text,
      status: 'pending'
    });
  }

  // ── Load history ──
  async function loadHistory() {
    if (!roomId) return;
    const { data } = await supabase
      .from('commands').select('*').eq('room_id', roomId)
      .order('created_at', { ascending: true }).limit(50);

    if (data) {
      chatArea.innerHTML = '';
      data.forEach((cmd: any) => {
        addBubble(cmd.input, 'user');
        if (cmd.message) addBubble(cmd.message, 'ray');
      });
    }
  }

  await loadHistory();

  // ── Realtime responses ──
  supabase.channel(`cmd-${roomCode}`)
    .on('postgres_changes', {
      event: 'UPDATE', schema: 'public', table: 'commands',
      filter: `room_id=eq.${roomId}`
    }, (payload: any) => {
      const cmd = payload.new;
      if (cmd.status === 'done' || cmd.status === 'error') {
        const typing = document.getElementById('typing');
        if (typing) typing.remove();
        if (cmd.message) addBubble(cmd.message, 'ray');
      }
    })
    .subscribe();

  // ── Chips ──
  document.querySelectorAll('.chip').forEach(chip => {
    chip.addEventListener('click', () => {
      input.value = chip.getAttribute('data-cmd') || '';
      btnSend.disabled = false;
      sendMessage();
    });
  });

  // ── Back ──
  document.getElementById('btn-back')!.addEventListener('click', () => {
    window.location.href = '/app/dashboard';
  });

  // ── Mic ──
  const btnMic = document.getElementById('btn-mic')!;
  let recognition: any = null;

  if ('webkitSpeechRecognition' in window || 'SpeechRecognition' in window) {
    const SpeechRecognition = (window as any).SpeechRecognition || (window as any).webkitSpeechRecognition;
    recognition = new SpeechRecognition();
    recognition.lang = 'es-ES';
    recognition.continuous = false;

    recognition.onresult = (e: any) => {
      const text = e.results[0][0].transcript;
      input.value = text;
      btnSend.disabled = false;
      btnMic.classList.remove('recording');
    };
    recognition.onend = () => { btnMic.classList.remove('recording'); };

    btnMic.addEventListener('click', () => {
      if (btnMic.classList.contains('recording')) {
        recognition.stop();
      } else {
        recognition.start();
        btnMic.classList.add('recording');
      }
    });
  } else {
    btnMic.style.display = 'none';
  }
</script>
