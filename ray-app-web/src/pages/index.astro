---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Ray App - Control remoto con IA">
  <script is:inline>
    // Si la URL recibe ?code= (desde el .exe), redirigir directamente a la página de sala.
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.get('code')) {
      window.location.href = '/pc?code=' + urlParams.get('code');
    }
  </script>
  
  <div class="landing-container">
    <header class="landing-header">
      <div class="logo">Ray<span class="dot">.</span></div>
      <a href="/app" class="btn-login">Ir a la Web App</a>
    </header>

    <main class="hero">
      <h1 class="title">Tu PC, en la palma de tu mano.</h1>
      <p class="subtitle">Descarga Ray Agent para Windows, muéstralo en pantalla y contrólalo usando inteligencia artificial desde tu móvil.</p>

      <div class="cta-group">
        <a href="/RayAgent.exe" download class="btn-primary btn-large">📥 Descargar RayAgent.exe</a>
        <p class="hint">Para Windows 10/11 · Funciona en segundo plano</p>
      </div>

      <div class="features-preview">
        <div class="feature-item">
          <span class="icon">💬</span>
          <span>Chat Inteligente</span>
        </div>
        <div class="feature-item">
          <span class="icon">⚡</span>
          <span>Control Rápido</span>
        </div>
        <div class="feature-item">
          <span class="icon">🔒</span>
          <span>Seguro & Privado</span>
        </div>
      </div>
    </main>
  </div>
</Layout>

<style>
  .landing-container {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: radial-gradient(circle at top center, #1a1a2e 0%, #0a0a0f 100%);
    padding: 0 8%;
  }

  .landing-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 30px 0;
  }

  .logo { font-size: 1.8rem; font-weight: 800; color: #fff; letter-spacing: -1px; }
  .dot { color: var(--accent); }

  .btn-login {
    color: #fff;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    padding: 10px 20px;
    background: rgba(255,255,255,0.1);
    border-radius: 20px;
    transition: 0.2s ease;
  }
  .btn-login:hover { background: var(--accent); color: #fff; }

  .hero {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
    padding-bottom: 8vh;
  }

  .title {
    font-size: 3.8rem;
    line-height: 1.1;
    margin-bottom: 24px;
    color: #fff;
    font-weight: 800;
  }

  .subtitle {
    font-size: 1.25rem;
    color: var(--text-muted);
    margin-bottom: 48px;
    line-height: 1.5;
    max-width: 600px;
  }

  .cta-group { margin-bottom: 60px; }

  .btn-large {
    padding: 18px 40px;
    font-size: 1.15rem;
    font-weight: 600;
    border-radius: 30px;
    text-decoration: none;
    display: inline-block;
    background: var(--accent);
    color: #fff;
    box-shadow: 0 10px 30px var(--accent-glow);
    transition: transform 0.2s;
  }
  .btn-large:hover { transform: translateY(-3px); box-shadow: 0 15px 40px var(--accent-glow); }

  .hint {
    margin-top: 18px;
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .features-preview {
    display: flex;
    gap: 40px;
    justify-content: center;
    flex-wrap: wrap;
    padding-top: 40px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: 12px;
    color: var(--text-muted);
    font-size: 1.05rem;
    font-weight: 500;
  }
  .feature-item .icon { font-size: 1.4rem; }

  @media (max-width: 768px) {
    .title { font-size: 2.8rem; }
    .subtitle { font-size: 1.1rem; }
    .features-preview { gap: 20px; flex-direction: column; align-items: center; }
  }
</style>
